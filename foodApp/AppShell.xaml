<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="foodApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:foodApp.Pages"
    Title="Food Encyclopedia"
    FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A161C}"
    Shell.ForegroundColor="{AppThemeBinding Light=#3A3A3A, Dark=#F0E8F0}"
    Shell.TitleColor="{AppThemeBinding Light=#3A3A3A, Dark=#F0E8F0}"
    Shell.UnselectedColor="{AppThemeBinding Light=#B0A0B8, Dark=#685878}"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A161C}"
    Shell.TabBarForegroundColor="#DEB7C1"
    Shell.TabBarTitleColor="#DEB7C1"
    Shell.TabBarUnselectedColor="{AppThemeBinding Light=#B0A0B8, Dark=#685878}">

    <TabBar>
        <ShellContent
            Title="Encyclopedia"
            ContentTemplate="{DataTemplate pages:MainPage}"
            Route="MainPage" />
        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate pages:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>
</Shell>
