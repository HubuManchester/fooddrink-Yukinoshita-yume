<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="foodApp.Pages.MapPage"
             Title="Select Location on Map"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#1A161C}">
    <Grid RowDefinitions="*,Auto">
        <maps:Map x:Name="LocationMap"
                  Grid.Row="0"
                  MapType="Street"
                  IsShowingUser="False"
                  MapClicked="OnMapClicked" />

        <Border Grid.Row="1" StrokeThickness="0" Padding="14"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1A161C}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0" />
            </Border.StrokeShape>
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                <Label x:Name="SelectedCoordLabel"
                       Text="No location selected. Tap on the map."
                       FontSize="13"
                       TextColor="{AppThemeBinding Light=#888, Dark=#B0A8B8}"
                       HorizontalTextAlignment="Center" />
                <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Text="Back"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#888, Dark=#B0A8B8}"
                            BorderColor="{AppThemeBinding Light=#E8E0E8, Dark=#3A3040}"
                            BorderWidth="1"
                            Clicked="OnBackClicked" />
                    <Button Grid.Column="1"
                            Text="Confirm Location"
                            BackgroundColor="#DEB7C1"
                            TextColor="#FFFFFF"
                            Clicked="OnConfirmClicked" />
                </Grid>
                <Label x:Name="StatusLabel"
                       Grid.Row="2"
                       Text="Map may need a Google Maps API key on Android."
                       FontSize="11"
                       TextColor="{AppThemeBinding Light=#B0B0B0, Dark=#685878}"
                       HorizontalTextAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>
