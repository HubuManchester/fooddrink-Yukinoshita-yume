<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="foodApp.Pages.FoodDetailPage"
             Title="Food Details"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#1A161C}">
    <ScrollView>
        <VerticalStackLayout Padding="18" Spacing="14">
            <Border StrokeThickness="0" Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#DEB7C1" Offset="0.0" />
                        <GradientStop Color="#C3B9D9" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                    <Label x:Name="NameLabel"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF" />
                    <Label x:Name="RegionLabel"
                           Grid.Row="1"
                           FontSize="15"
                           TextColor="#FFFFFF" />
                    <Label x:Name="UploadedByLabel"
                           Grid.Row="2"
                           FontSize="13"
                           TextColor="#FFFFFF" />
                </Grid>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E8E0E8, Dark=#3A3040}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#25202A}"
                    Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Photo" FontSize="15" FontAttributes="Bold" TextColor="#C3B9D9" />
                    <Border StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#E8E0E8, Dark=#3A3040}"
                            BackgroundColor="{AppThemeBinding Light=#FAF8FA, Dark=#2A2430}"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Image x:Name="FoodImage"
                               HeightRequest="200"
                               Aspect="AspectFit" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E8E0E8, Dark=#3A3040}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#25202A}"
                    Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Description" FontSize="15" FontAttributes="Bold" TextColor="#DEB7C1" />
                    <Label x:Name="DescriptionLabel"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#666, Dark=#B0A8B8}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
