<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="foodApp.Pages.LoginPage"
             Title="Login"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">
    <ScrollView>
        <VerticalStackLayout Padding="28" Spacing="18" VerticalOptions="Center" MaximumWidthRequest="420">

            <Label Text="Food Encyclopedia"
                   FontSize="34"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="#DEB7C1" />
            <Label Text="Discover and share food from around the world"
                   FontSize="15"
                   HorizontalTextAlignment="Center"
                   TextColor="#888"
                   Margin="0,0,0,10" />

            <Entry x:Name="UsernameEntry"
                   Placeholder="Username"
                   ReturnType="Next" />

            <Entry x:Name="PasswordEntry"
                   Placeholder="Password"
                   IsPassword="True"
                   ReturnType="Done" />

            <Label x:Name="ErrorLabel"
                   IsVisible="False"
                   TextColor="#E06060"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />

            <Button Text="Login"
                    BackgroundColor="#DEB7C1"
                    TextColor="#FFFFFF"
                    FontAttributes="Bold"
                    Clicked="OnLoginClicked" />

            <Button Text="Create new account"
                    BackgroundColor="Transparent"
                    TextColor="#C3B9D9"
                    BorderColor="#C3B9D9"
                    BorderWidth="1"
                    Clicked="OnGoToRegisterClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
