<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="foodApp.Pages.AddFoodPage"
             Title="Add Food"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#1A161C}">
    <ScrollView>
        <VerticalStackLayout Padding="18" Spacing="14">
            <Border StrokeThickness="0" Padding="16"
                    BackgroundColor="{AppThemeBinding Light=#FAF8FA, Dark=#28222C}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                    <Label Text="Add Food Entry"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#DEB7C1" />
                    <Label Grid.Row="1"
                           Text="Share a food from anywhere in the world."
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#888, Dark=#B0A8B8}" />
                </Grid>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E8E0E8, Dark=#3A3040}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#25202A}"
                    Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Food Information" FontSize="15" FontAttributes="Bold" TextColor="#C3B9D9" />
                    <Entry x:Name="NameEntry" Placeholder="Food name" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry x:Name="RegionEntry" Placeholder="Region (e.g. Tokyo, Japan)" />
                        <Button Grid.Column="1"
                                Text="Map"
                                FontSize="12"
                                Padding="10,8"
                                BackgroundColor="#C3B9D9"
                                TextColor="#FFFFFF"
                                Clicked="OnSelectFromMapClicked" />
                    </Grid>
                    <Editor x:Name="DescriptionEditor"
                            Placeholder="Description, ingredients, or story behind the food"
                            AutoSize="TextChanges"
                            HeightRequest="90" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E8E0E8, Dark=#3A3040}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#25202A}"
                    Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Food Photo" FontSize="15" FontAttributes="Bold" TextColor="#C3B9D9" />
                    <Image x:Name="PreviewImage"
                           HeightRequest="180"
                           Aspect="AspectFit"
                           BackgroundColor="{AppThemeBinding Light=#FAF8FA, Dark=#2A2430}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="Take Photo"
                                BackgroundColor="#DEB7C1"
                                TextColor="#FFFFFF"
                                Clicked="OnTakePhotoClicked" />
                        <Button Grid.Column="1"
                                Text="Choose from Gallery"
                                BackgroundColor="#C3B9D9"
                                TextColor="#FFFFFF"
                                Clicked="OnPickFromGalleryClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ValidationPanel"
                    IsVisible="False"
                    StrokeThickness="0"
                    BackgroundColor="#FFE8E8"
                    Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Label x:Name="ValidationLabel"
                       TextColor="#C04040"
                       FontAttributes="Bold" />
            </Border>

            <Button Text="Save Entry"
                    FontAttributes="Bold"
                    BackgroundColor="#DEB7C1"
                    TextColor="#FFFFFF"
                    Clicked="OnSaveClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
