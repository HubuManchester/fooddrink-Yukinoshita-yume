<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="foodApp.Pages.AddFoodPage"
             Title="Add Food">
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#FFF1DA, Dark=#130F0C}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#FFF9EF, Dark=#0F1711}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>
        <VerticalStackLayout Padding="22" Spacing="16">
            <Border StrokeThickness="0" Padding="18" BackgroundColor="{AppThemeBinding Light=#FFFDF8, Dark=#1A1712}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                    <Label Text="Add Food Entry"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Grid.Row="1"
                           Text="Share a food from anywhere in the world."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}" />
                </Grid>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Label Text="Food Information" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}" />
                    <Entry x:Name="NameEntry"
                           Placeholder="Food name"
                           SemanticProperties.Hint="Required food name" />
                    <Entry x:Name="RegionEntry"
                           Placeholder="Region (e.g. Tokyo, Japan)"
                           SemanticProperties.Hint="Where this food comes from" />
                    <Editor x:Name="DescriptionEditor"
                            Placeholder="Description, ingredients, flavour, or story behind the food"
                            AutoSize="TextChanges"
                            HeightRequest="104"
                            SemanticProperties.Hint="Describe this food" />
                    <Entry x:Name="ImageUrlEntry"
                           Placeholder="Image URL (optional)"
                           Keyboard="Url" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ValidationPanel"
                    IsVisible="False"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#FFE8E0, Dark=#40201C}"
                    Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Label x:Name="ValidationLabel"
                       TextColor="{AppThemeBinding Light=#B43820, Dark=#FFB4A6}"
                       FontAttributes="Bold" />
            </Border>

            <Button Text="Save Entry"
                    FontAttributes="Bold"
                    BackgroundColor="#D9472B"
                    TextColor="#FFFFFF"
                    Clicked="OnSaveClicked"
                    SemanticProperties.Hint="Validate and save this food entry" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
