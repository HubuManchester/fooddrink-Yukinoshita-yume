<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="foodApp.Pages.SettingsPage"
             Title="Settings"
             BackgroundColor="White">
    <ScrollView>
        <VerticalStackLayout Padding="18" Spacing="14">
            <Border StrokeThickness="0" Padding="16" BackgroundColor="#FAF8FA">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Accessibility Settings"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#DEB7C1" />
                    <Label Text="Large text takes effect immediately and stays on when switching pages."
                           FontSize="14"
                           TextColor="#888" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1" Stroke="#E8E0E8" BackgroundColor="White" Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                        <Label Text="Theme Mode"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#DEB7C1" />
                        <Picker x:Name="ThemePicker"
                                Grid.Row="1"
                                Title="Choose app theme"
                                SelectedIndexChanged="OnThemeChanged">
                            <Picker.Items>
                                <x:String>Use system theme</x:String>
                                <x:String>Light theme</x:String>
                                <x:String>Dark theme</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#E8E0E8" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Large Text Mode"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#C3B9D9" />
                            <Label Text="Increase text size across the app."
                                   FontSize="12"
                                   TextColor="#888" />
                        </VerticalStackLayout>
                        <Switch x:Name="LargeTextSwitch"
                                Grid.Column="1"
                                Toggled="OnLargeTextToggled" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="0" BackgroundColor="#FAF8FA" Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label x:Name="LargeTextPreviewTitle"
                           Text="Large text preview"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#C3B9D9" />
                    <Label x:Name="LargeTextPreviewBody"
                           Text="When enabled, this text and the rest of the page become visibly larger."
                           FontSize="14"
                           TextColor="#888" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Logout"
                    BackgroundColor="Transparent"
                    TextColor="#C06060"
                    BorderColor="#C06060"
                    BorderWidth="1"
                    Clicked="OnLogoutClicked" />

            <Label x:Name="SettingsStatusLabel"
                   Text="Settings ready."
                   FontAttributes="Bold"
                   TextColor="#DEB7C1" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
