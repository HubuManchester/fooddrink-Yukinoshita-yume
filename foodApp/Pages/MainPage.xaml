<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:foodApp.Models"
             xmlns:behaviors="clr-namespace:foodApp.Behaviors"
             x:Class="foodApp.Pages.MainPage"
             x:Name="ThisPage"
             Title="Food Encyclopedia"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#1A161C}">
    <Grid RowDefinitions="Auto,*">
        <Border StrokeThickness="0" Padding="18" Margin="14,14,14,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#DEB7C1" Offset="0.0" />
                    <GradientStop Color="#C3B9D9" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <VerticalStackLayout Spacing="10">
                <Label Text="Food Encyclopedia"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#FFFFFF" />
                <Label Text="Browse, search, and share food from around the world."
                       FontSize="14"
                       TextColor="#FFFFFF" />
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Margin="0,6,0,0">
                    <Border StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#E8E0E8, Dark=#3A3040}"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#25202A}"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <SearchBar x:Name="SearchFoodBar"
                                   Placeholder="Search foods, regions, or tags"
                                   TextChanged="OnSearchTextChanged"
                                   SearchButtonPressed="OnSearchButtonPressed"
                                   TextColor="{AppThemeBinding Light=#3A3A3A, Dark=#F0E8F0}"
                                   PlaceholderColor="{AppThemeBinding Light=#A0A0A0, Dark=#908898}"
                                   BackgroundColor="Transparent" />
                    </Border>
                    <Button Grid.Column="1"
                            Text="Random"
                            FontSize="12"
                            Padding="10,8"
                            BackgroundColor="#C3B9D9"
                            TextColor="#FFFFFF"
                            Clicked="OnRandomClicked" />
                    <Button Grid.Column="2"
                            Text="Add"
                            BackgroundColor="#DEB7C1"
                            TextColor="#FFFFFF"
                            FontAttributes="Bold"
                            Clicked="OnAddClicked" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <RefreshView Grid.Row="1" x:Name="FoodRefreshView" Refreshing="OnRefreshing">
            <CollectionView x:Name="FoodCollection"
                            SelectionMode="None"
                            EmptyView="No matching food entries found."
                            RemainingItemsThreshold="2"
                            RemainingItemsThresholdReached="OnRemainingItemsThresholdReached"
                            Margin="14,8,14,14">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="1"
                                     HorizontalItemSpacing="10"
                                     VerticalItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:FoodItem">
                        <Border StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E8E0E8, Dark=#3A3040}"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#25202A}"
                                Padding="12"
                                Margin="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Border.Behaviors>
                                <behaviors:LongPressBehavior
                                    Command="{Binding Source={x:Reference ThisPage}, Path=LongPressCommand}"
                                    CommandParameter="{Binding Name}" />
                            </Border.Behaviors>
                            <Grid ColumnDefinitions="70,*" ColumnSpacing="12">
                                <Border StrokeThickness="1"
                                        Stroke="{AppThemeBinding Light=#E8E0E8, Dark=#3A3040}"
                                        BackgroundColor="{AppThemeBinding Light=#FAF8FA, Dark=#2A2430}"
                                        Padding="0"
                                        HeightRequest="70"
                                        WidthRequest="70">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>
                                    <Image Source="{Binding ImageUrl}"
                                           Aspect="AspectFill"
                                           HeightRequest="70"
                                           WidthRequest="70" />
                                </Border>
                                <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
                                    <Label Text="{Binding Name}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#3A3A3A, Dark=#F0E8F0}" />
                                    <Label Grid.Row="1"
                                           Text="{Binding RegionLabel}"
                                           FontSize="12"
                                           TextColor="#C3B9D9"
                                           FontAttributes="Bold" />
                                    <Label Grid.Row="2"
                                           Text="{Binding Description}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#888, Dark=#B0A8B8}"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2" />
                                    <HorizontalStackLayout Grid.Row="3" Spacing="8">
                                        <Label FontSize="11" TextColor="{AppThemeBinding Light=#B0B0B0, Dark=#908898}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="By " />
                                                    <Span Text="{Binding UploadedBy}" FontAttributes="Bold" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                        <Button Text="Details"
                                                Padding="10,5"
                                                FontSize="11"
                                                BackgroundColor="#C3B9D9"
                                                TextColor="#FFFFFF"
                                                CommandParameter="{Binding Id}"
                                                Clicked="OnDetailsClicked" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Loading indicator at the bottom -->
        <ActivityIndicator Grid.Row="1"
                           x:Name="LoadingMoreIndicator"
                           IsVisible="False"
                           IsRunning="False"
                           VerticalOptions="End"
                           HorizontalOptions="Center"
                           Margin="0,0,0,20"
                           HeightRequest="30"
                           Color="#C3B9D9" />
    </Grid>
</ContentPage>
